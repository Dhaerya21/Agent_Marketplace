# AI Agent Marketplace - Environment Configuration
FLASK_ENV=production

# Security Keys (Generated automatically by ec2_setup.sh)
JWT_SECRET=change_me_in_production
MARKETPLACE_MASTER_KEY=change_me_in_production

# Database & Cache (Generated automatically by ec2_setup.sh)
DATABASE_URL=postgresql://marketplace_user:PASSWORD@localhost/marketplacedb
REDIS_URL=redis://:PASSWORD@localhost:6379/0

# Agent Integration URLs
RESEARCHER_URL=http://localhost:5001
DOCUMENTATION_URL=http://localhost:5002
CITATION_URL=http://localhost:5003
CODEREVIEW_URL=http://localhost:5004
DATAEXTRACTOR_URL=http://localhost:5005

# Ollama Endpoint Configuration
OLLAMA_URL=http://localhost:11434/api/generate
LLM_MODEL=qwen2.5:7b
