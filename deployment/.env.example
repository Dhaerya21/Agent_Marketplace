# AI Agent Marketplace — Environment Configuration
# Copy this file to .env and fill in values

# ── Flask ──────────────────────────────────────────────────────
FLASK_ENV=production
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_64_CHARS_MINIMUM
JWT_EXPIRES_HOURS=24

# ── Database ───────────────────────────────────────────────────
# SQLite (single EC2):
DATABASE_URL=sqlite:///marketplace.db
# PostgreSQL (RDS):
# DATABASE_URL=postgresql://user:password@mydb.xxxxx.us-east-1.rds.amazonaws.com:5432/marketplace

# ── Redis (ElastiCache or local) ───────────────────────────────
REDIS_URL=redis://localhost:6379/0
# ElastiCache:
# REDIS_URL=redis://my-cache.xxxxx.0001.use1.cache.amazonaws.com:6379/0

# ── CORS ───────────────────────────────────────────────────────
CORS_ORIGINS=https://your-domain.com

# ── Agent URLs (internal, same EC2) ───────────────────────────
RESEARCHER_URL=http://localhost:5001
DOCUMENTATION_URL=http://localhost:5002
CITATION_URL=http://localhost:5003

# ── Security ───────────────────────────────────────────────────
MAX_REQUEST_SIZE=32768
MAX_INPUT_LENGTH=8000
MARKETPLACE_MASTER_KEY=CHANGE_THIS_TO_A_RANDOM_KEY

# ── LLM ───────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434/api/generate
LLM_MODEL=qwen2.5:7b

# ── Server ────────────────────────────────────────────────────
MARKETPLACE_PORT=8080
